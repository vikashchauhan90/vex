{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Angular in Chrome",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:4200",
            "webRoot": "${workspaceFolder}/packages/vex-app/app/src",
            "sourceMapPathOverrides": {
                "webpack:///packages/vex-app/app/src/*": "${workspaceFolder}/packages/vex-app/app/src/*"
            }
        },
        {
            "name": "Debug Electron Main Process",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
            "program": "${workspaceFolder}/packages/vex-electron/main.js",
            "args": ["--dev"],
            "cwd": "${workspaceFolder}/packages/vex-electron",
            "env": {
                "NODE_ENV": "development"
            },
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Launch Angular Dev Server",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/packages/vex-app/app/node_modules/.bin/ng",
            "args": ["serve", "--port", "4200"],
            "cwd": "${workspaceFolder}/packages/vex-app/app",
            "console": "integratedTerminal",
            "preLaunchTask": "Build vex-common",
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ],
    "compounds": [
        {
            "name": "Debug VEX (Angular + Electron)",
            "configurations": ["Launch Angular Dev Server", "Debug Electron Main Process"],
            "stopAll": true
        }
    ]
}